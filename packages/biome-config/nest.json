{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "extends": ["./biome.json"],
  "linter": {
    "rules": {
      "correctness": {
        "noUnusedParameters": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "useNamingConvention": "off"
      },
      "suspicious": {
        "noExplicitAny": "warn"
      }
    }
  }
}
