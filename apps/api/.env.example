# Variáveis de ambiente — Hyper Finance API
NODE_ENV=development
PORT=3333

# JWT — ECDSA P-256 (ES256) — chaves assimétricas, base64-encoded PEM single-line
JWT_PRIVATE_KEY=<base64-encoded-ec-p256-pkcs8-pem>
JWT_PUBLIC_KEY=<base64-encoded-ec-p256-spki-pem>
JWT_EXPIRES_IN=15m

# Pepper — segredo do servidor, NUNCA armazenado no banco de dados (Mínimo 32 caracteres aleatórios)
PEPPER=change-me-to-a-random-256-bit-pepper-at-least-32-chars

# Custo do bcrypt (10–14). Valores maiores = mais lento = mais seguro.
BCRYPT_ROUNDS=12

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_USER=user
POSTGRES_PASSWORD=change_me_local
POSTGRES_DB=hyper_finance
POSTGRES_PORT=5432
