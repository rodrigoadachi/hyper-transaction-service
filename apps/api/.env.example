# Variáveis de ambiente — Hyper Finance API
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA commite o .env — apenas o .env.example.

PORT=3333

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_USER=user
POSTGRES_PASSWORD=change_me_local
POSTGRES_DB=hyper_finance
POSTGRES_PORT=5432

# JWT — EdDSA Ed25519 (assimétrico, melhor segurança + performance)
# Gerar par de chaves:
#   node -e "const {generateKeyPairSync}=require('crypto');const {privateKey,publicKey}=generateKeyPairSync('ed25519',{privateKeyEncoding:{type:'pkcs8',format:'pem'},publicKeyEncoding:{type:'spki',format:'pem'}});console.log('PRIVATE='+Buffer.from(privateKey).toString('base64'));console.log('PUBLIC='+Buffer.from(publicKey).toString('base64'));"
JWT_PRIVATE_KEY=<base64-encoded-ed25519-pkcs8-pem>
JWT_PUBLIC_KEY=<base64-encoded-ed25519-spki-pem>
JWT_EXPIRES_IN=15m

# Pepper — segredo do servidor, NUNCA armazenado no banco de dados
# Se comprometido, gerar novo pepper e forçar reset de senha de todos os usuários.
# Mínimo 32 caracteres aleatórios.
PEPPER=change-me-to-a-random-256-bit-pepper-at-least-32-chars

# Custo do bcrypt (10–14). Valores maiores = mais lento = mais seguro.
# 12 é o recomendado para produção em 2026.
BCRYPT_ROUNDS=12
