{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@hyper/typescript-config/vite.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"ignoreDeprecations": "5.0",
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"./src/*"
			]
		},
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo"
	},
	"include": [
		"src",
		"vite.config.ts",
		"index.html"
	]
}